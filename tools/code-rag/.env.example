OLLAMA_URL=http://host.docker.internal:11434
EMBED_MODEL=qwen3-embedding:0.6b
COLLECTION=code_rag
TOP_K=15
RERANK_CANDIDATES=50
RERANK_TEXT_CHARS=256
# drop results below this reranker score (0..1) → higher precision; 0 disables. Calibrate per model:
# probe a good query vs a garbage query, put the cutoff in the gap (bge-reranker-v2-m3: ~0.05).
RERANK_MIN_SCORE=0.05
# file types to index (comma-separated) — override for your stack; default covers common languages + docs
# INCLUDE_EXT=.py,.ts,.go,.md
# EXCLUDE_DIRS=build,.git,node_modules,dist,target,.venv
RERANKER_URL=http://reranker:80
RERANK_ENABLED=true
RERANK_TIMEOUT=60
# reranker service (its own container) — prebuilt quantized ONNX, no local export:
RERANKER_MODEL=onnx-community/bge-reranker-v2-m3-ONNX
RERANKER_ONNX_FILE=onnx/model_quantized.onnx
ORT_THREADS=6
# Optional — HF read token for higher Hub rate limits / faster model downloads (public models work without it)
HF_TOKEN=
