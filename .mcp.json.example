{
  "_comment": "Example MCP servers. Copy the entries you want into your own .mcp.json (gitignored). The OpenAlex research MCP needs no secret — OpenAlex's API is free/keyless; OPENALEX_EMAIL is just for the polite-rate pool, put your own. Pinned version = supply-chain safety. See .docs/common-issues/openalex-evidence-verify-per-record-not-by-source.md for how to use it.",
  "mcpServers": {
    "openalex": {
      "command": "npx",
      "args": [
        "-y",
        "openalex-research-mcp@0.5.0"
      ],
      "env": {
        "OPENALEX_EMAIL": "you@example.com"
      }
    }
  }
}
